# Loot-action loop-slice dedicated server — /etc/default/loop-slice-server
#
# The headless authority binds LOOP_HOST:LOOP_PORT and accepts WebTransport/QUIC
# clients. After editing: systemctl restart loop-slice-server
LOOP_HOST=0.0.0.0
LOOP_PORT=54400

# Optional: maximum concurrent players (the slice's loop runs four).
#LOOP_MAX_PLAYERS=4
